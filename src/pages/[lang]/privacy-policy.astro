---
import type { MarkdownInstance } from 'astro';
import Layout from '../../layouts/Layout.astro';
import {
  getLangStaticPaths,
  useTranslations,
  defaultLang,
  type Lang,
} from '../../i18n/utils';

export function getStaticPaths() {
  return getLangStaticPaths();
}

const lang = (Astro.params.lang ?? defaultLang) as Lang;
const t = useTranslations(lang);

const pages = import.meta.glob<MarkdownInstance<Record<string, any>>>(
  '../../legal/privacy-policy.*.md',
  { eager: true }
);
const entry = pages[`../../legal/privacy-policy.${lang}.md`];
if (!entry) throw new Error(`Missing legal content: privacy-policy.${lang}.md`);
const { Content, frontmatter } = entry;
---

<Layout
  lang={lang}
  title={frontmatter.title ?? t('meta.privacy.title')}
  description={frontmatter.description ?? t('meta.privacy.description')}
>
  <section class="mx-auto max-w-3xl px-6 py-20 md:py-28">
    <article class="prose prose-slate max-w-none prose-blockquote:border-carmine prose-blockquote:text-secondary prose-a:text-carmine">
      <Content />
    </article>
  </section>
</Layout>
