---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Values from '../../components/Values.astro';
import About from '../../components/About.astro';
import Gallery from '../../components/Gallery.astro';
import Contact from '../../components/Contact.astro';
import {
  getLangStaticPaths,
  useTranslations,
  defaultLang,
  type Lang,
} from '../../i18n/utils';

export function getStaticPaths() {
  return getLangStaticPaths();
}

const lang = (Astro.params.lang ?? defaultLang) as Lang;
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('meta.home.title')} description={t('meta.home.description')}>
  <Hero lang={lang} />

  <section class="border-y border-pearl/40 bg-sage/30 py-16">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2 class="text-2xl md:text-3xl">{t('intro.title')}</h2>
      <p class="mt-5 text-lg leading-relaxed text-secondary">{t('intro.text')}</p>
    </div>
  </section>

  <About lang={lang} />
  <Values lang={lang} />
  <Gallery lang={lang} />
  <Contact lang={lang} />
</Layout>
