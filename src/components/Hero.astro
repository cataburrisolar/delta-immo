---
import { useTranslations, localizePath, type Lang } from '../i18n/utils';
import ImagePlaceholder from './ImagePlaceholder.astro';
import ImageWithRatio from './ImageWithRatio.astro'

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const home = localizePath(lang);
---

<section class="relative overflow-hidden">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 md:grid-cols-2 md:py-28">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-carmine">
        {t('hero.eyebrow')}
      </p>
      <h1 class="text-4xl leading-tight md:text-5xl lg:text-6xl">
        {t('hero.title')}
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-secondary">
        {t('hero.subtitle')}
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href={`${home}#contact`} class="btn-primary">{t('hero.ctaPrimary')}</a>
        <a href={`${home}#about`} class="btn-secondary">{t('hero.ctaSecondary')}</a>
      </div>
    </div>

    <div class="md:pl-6">
      <!-- <ImagePlaceholder
        description={t('hero.imagePlaceholder')}
        class="aspect-[4/3] shadow-[0_8px_30px_rgba(0,0,0,0.08)]"
      /> -->
      <ImageWithRatio class='rounded-md shadow-[0_8px_30px_rgba(0,0,0,0.08)]' 
        aspectRatio='4/3' src='/properties/Image_1.png' />
    </div>
  </div>
</section>
