---
import { getTranslations, type Lang } from '../i18n/utils';
import ImageWithRatio from './ImageWithRatio.astro'

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = getTranslations(lang).gallery;

import Image_1 from '../assets/properties/Image_1.png'
import Image_2 from '../assets/properties/Image_2.png'
import Image_3 from '../assets/properties/Image_3.png'
import Image_4 from '../assets/properties/Image_4.png'
import Image_5 from '../assets/properties/Image_5.png'

const galleryImages = [
  {imageData: Image_5},
  {imageData: Image_3},
  {imageData: Image_4},
  {imageData: Image_1},
  {imageData: Image_2},
];
---

<section id="gallery" class="scroll-mt-20 bg-sage/30 py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-carmine">
        {c.eyebrow}
      </p>
      <h2 class="text-3xl md:text-4xl">{c.title}</h2>
      <p class="mt-4 text-lg leading-relaxed text-secondary">{c.subtitle}</p>
    </div>

    <div class="mt-14 flex flex-wrap justify-center gap-6">
      {
        galleryImages.map((img) => (
          <div class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
            <ImageWithRatio
              class="rounded-[2px] shadow-[0_8px_30px_rgba(0,0,0,0.08)]"
              aspectRatio="4/3"
              imageData={img.imageData}
              widths={[1000]}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
