---
import { useTranslations, localizePath, type Lang } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const home = localizePath(lang);

const navLinks = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#values`, label: t('nav.values') },
  { href: `${home}#gallery`, label: t('nav.gallery') },
  { href: `${home}#contact`, label: t('nav.contact') },
];
---

<header class="sticky top-0 z-50 border-b border-offwhite/10 bg-slate text-offwhite backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href={home} class="shrink-0" aria-label="Delta Immo">
      <img src="/delta-immo.svg" alt="Delta Immo" class="h-9 w-auto brightness-0 invert" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-offwhite/80 transition-colors hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-5 md:flex">
      <LanguageSwitcher lang={lang} tone="onDark" />
      <a href={`${home}#contact`} class="btn-primary text-sm">{t('nav.cta')}</a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="flex items-center justify-center rounded p-2 text-offwhite md:hidden"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-offwhite/10 bg-slate text-offwhite md:hidden">
    <nav class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-4" aria-label="Mobile">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded px-2 py-2 text-offwhite/80 transition-colors hover:bg-white/5 hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
      <div class="mt-3 flex items-center justify-between border-t border-offwhite/10 pt-4">
        <LanguageSwitcher lang={lang} tone="onDark" />
        <a href={`${home}#contact`} class="btn-primary text-sm">{t('nav.cta')}</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
  menu?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
