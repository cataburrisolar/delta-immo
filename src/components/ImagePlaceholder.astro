---
interface Props {
  description: string;
  /** Extra classes for sizing/aspect ratio, e.g. "aspect-video". */
  class?: string;
}

const { description, class: className = '' } = Astro.props;
---

<div
  class={`flex flex-col items-center justify-center gap-3 rounded-[12px] border border-dashed border-pearl bg-sage/40 p-6 text-center ${className}`}
  role="img"
  aria-label={description}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="40"
    height="40"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.25"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="text-slate/50"
    aria-hidden="true"
  >
    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
    <circle cx="8.5" cy="8.5" r="1.5"></circle>
    <path d="M21 15l-5-5L5 21"></path>
  </svg>
  <span class="max-w-md text-sm leading-relaxed text-secondary">{description}</span>
</div>
